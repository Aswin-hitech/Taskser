NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/taskser
FRONTEND_URL=http://localhost:3000

ACCESS_TOKEN_SECRET=change_me_access_secret
REFRESH_TOKEN_SECRET=change_me_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
REFRESH_COOKIE_NAME=taskser_refresh
BCRYPT_ROUNDS=10

CONTEST_SYNC_CRON=*/30 * * * *
CONTEST_REMINDER_CRON=* * * * *

LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

NINJA_QUOTES_API_KEY=your_api_ninjas_key_here
